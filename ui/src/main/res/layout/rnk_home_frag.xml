<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_50">

    <!-- Top Background Curve -->
    <View
        android:id="@+id/topCurve"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#0D1E3A8A"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Right Button: Полномочия -->
    <LinearLayout
        android:id="@+id/btnAuthorities"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_button_authorities"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="35dp"
        android:elevation="2dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/fr_home_gost"
        app:layout_constraintEnd_toEndOf="parent">
        
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_file_badge"
            android:layout_marginEnd="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПОЛНОМОЧИЯ"
            android:textColor="#334155"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Header -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="РОСКОМНАДЗОР"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/slate_900"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/badgeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ЗАЩИТА"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@color/blue_600"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/badgeText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:id="@+id/statusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Защита суверенитета включена"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/emerald_600" />
            
        <TextView
            android:id="@+id/statusDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Трафик инспектируется. Угроз не обнаружено."
            android:textSize="14sp"
            android:textColor="@color/slate_500"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Pulse View -->
    <View
        android:id="@+id/pulseView"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_pulse"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/statusContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Main Button -->
    <FrameLayout
        android:id="@+id/mainButton"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_button_protected"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/statusContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_logo_protected" />
    </FrameLayout>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/fr_home_gost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ГОСТ Р 34.12-2015"
            android:textSize="12sp"
            android:textColor="@color/slate_400" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Лицензия ФСТЭК №4525783"
            android:textSize="12sp"
            android:textColor="@color/slate_400"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
