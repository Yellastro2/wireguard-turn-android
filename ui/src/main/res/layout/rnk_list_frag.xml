<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F172A"
        android:padding="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_file_badge_light"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="РЕЕСТР ПОЛНОМОЧИЙ"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="monospace" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="32dp"
                app:cardElevation="4dp">

                <!-- Citizen Key Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:elevation="1dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toTopOf="@+id/fr_auths_key_layout"
                        app:layout_constraintBottom_toBottomOf="@+id/fr_auths_key_layout"
                        android:background="#2563EB" />

                    <LinearLayout
                        android:id="@+id/fr_auths_key_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="КЛЮЧ ДОСТУПА ГРАЖДАНИНА"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/etCitizenKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="12dp"
                            android:text="RU-77-XF90-2026-BETA"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.05"
                            android:inputType="text" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="* ИДЕНТИФИКАТОР ПРИВЯЗАН К УЧЕТНОЙ ЗАПИСИ ГОСУСЛУГ"
                            android:textColor="#94A3B8"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Nodes Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_server"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="УЗЛЫ СВЯЗИ (КОНФИГУРАЦИИ)"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <ImageView
                    android:id="@+id/btnAddNode"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Nodes List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNodes"
                tools:itemCount="3"
                tools:listitem="@layout/item_node"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
