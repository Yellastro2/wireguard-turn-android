<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ФОРМА №42-В: КОНФИГУРАЦИЯ УЗЛА"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Редактирование параметров защищенного туннеля"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ОТМЕНА"
            android:textColor="#475569"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2563EB"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_save"
                android:layout_marginEnd="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="УТВЕРДИТЬ"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/fr_edit_scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Interface -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="СЕКЦИЯ 1: ИНТЕРФЕЙС"
                        android:textColor="#1E293B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="#F1F5F9"
                        android:padding="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/white"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="НАИМЕНОВАНИЕ"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etNodeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ЗАКРЫТЫЙ КЛЮЧ (PRIVATE KEY)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <EditText
                                android:id="@+id/etPrivateKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input"
                                android:padding="10dp"
                                android:paddingEnd="40dp"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:inputType="textPassword"
                                android:text="gost-private-key-mock-data-123" />
                            <ImageView
                                android:id="@+id/fr_edit_key_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_key"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="12dp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ОТКРЫТЫЙ КЛЮЧ (PUBLIC KEY)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etPublicKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_disabled"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:textColor="#94A3B8"
                            android:text="pub-key-generated-auto-456"
                            android:editable="false"
                            android:focusable="false"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="АДРЕСА (ADDRESSES)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etNodeIp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ПОРТ (LISTEN PORT)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etListenPort"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:hint="Случайный"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="СЕРВЕРЫ DNS"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etDns"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:text="77.88.8.8"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MTU"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etMtu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:hint="Автоматически"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="НАСТРОИТЬ ИСКЛЮЧЕНИЯ ПРИЛОЖЕНИЙ (0)"
                            android:textColor="#2563EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 2: TURN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#F1F5F9"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="СЕКЦИЯ 2: МАРШРУТИЗАЦИЯ TURN"
                            android:textColor="#1E293B"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchTurn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        tools:visibility="visible"
                        android:id="@+id/layoutTurnContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/white"
                        android:padding="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TURN ПИР (PEER)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etTurnPeer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:hint="Введите идентификатор пира"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TURN VK ССЫЛКА (VK LINK)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:visibility="gone"
                            android:id="@+id/etTurnVk"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:hint="https://vk.com/..."
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ПОТОКИ (STREAMS)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etTurnStreams"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:hint="Количество потоков"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ЛОКАЛЬНЫЙ ПОРТ (LOCAL PORT)"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />
                        <EditText
                            android:id="@+id/etTurnLocalPort"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="10dp"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:hint="Порт"
                            android:layout_marginBottom="16dp" />

                        <CheckBox
                            android:id="@+id/cbTurnUdp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ИСПОЛЬЗОВАТЬ UDP"
                            android:textColor="#334155"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnToggleAdvanced"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ПОКАЗАТЬ РАСШИРЕННЫЕ ПАРАМЕТРЫ"
                            android:textColor="#475569"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/layoutTurnAdvanced"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TURN IP"
                                android:textColor="#64748B"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etTurnIp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input"
                                android:padding="10dp"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:hint="IP-адрес"
                                android:layout_marginBottom="16dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TURN PORT"
                                android:textColor="#64748B"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etTurnPortAdv"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input"
                                android:padding="10dp"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:inputType="number"
                                android:hint="Порт"
                                android:layout_marginBottom="16dp" />

                            <CheckBox
                                android:id="@+id/cbTurnNoDtls"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ОТКЛЮЧИТЬ DTLS (NO DTLS)"
                                android:textColor="#334155"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section 3: Peers -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/fr_edit_peers_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:background="@color/white"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="СЕКЦИЯ 3: ДОВЕРЕННЫЕ УЗЛЫ (ПИРЫ)"
                        android:textColor="#1E293B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="#F1F5F9"
                        android:padding="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Список пиров пуст. Требуется добавление узла связи."
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:padding="32dp"
                        android:background="#F8FAFC" />

                    <LinearLayout
                        android:id="@+id/fr_edit_addpeer_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="#F1F5F9">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_add"
                            app:tint="#1D4ED8"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ДОБАВИТЬ ПИР"
                            android:textColor="#1D4ED8"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
