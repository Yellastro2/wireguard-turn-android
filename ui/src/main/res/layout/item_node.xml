<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_node_inactive"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_circle"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNodeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ГОСТ-УЗЕЛ-МСК-01"
            android:textColor="#334155"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvNodeIp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85.119.149.22"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_ip_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvNodeRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЦФО"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/ivDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
